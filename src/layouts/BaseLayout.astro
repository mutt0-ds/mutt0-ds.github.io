---
import '../styles/tokens.css';
import '../styles/components.css';
import SearchModal from '../components/SearchModal.astro';

interface Props {
  title: string;
  description?: string;
  wide?: boolean;
}

const { title, description = 'Notes on AI, data engineering, and software — written from Como.', wide = false } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate" type="application/rss+xml" title="Mutt0-ds Notes" href="/index.xml" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <header class="topbar">
      <div class="topbar-inner">
        <a class="mark" href="/" aria-label="home">
          <svg class="mark-icon" viewBox="-4 -4 168 268" aria-hidden="true">
            <path
              d="M0.00,259.31 C1.79,258.33 16.98,231.67 21.84,227.20 C26.70,222.73 41.54,225.26 43.76,219.05 C45.98,212.84 38.76,177.90 41.85,171.35 C44.94,164.80 65.29,164.62 71.60,160.06 C77.91,155.50 93.93,127.06 98.66,130.34 C103.39,133.62 107.26,178.04 114.20,189.62 C121.14,201.20 156.53,231.78 161.15,234.60 C165.77,237.42 159.97,220.23 155.79,215.00 C151.61,209.77 128.89,198.43 123.53,187.50 C118.17,176.57 107.56,128.18 107.55,116.63 C107.54,105.08 122.52,88.64 123.41,83.57 C124.30,78.50 115.71,75.94 115.57,71.04 C115.43,66.14 119.48,43.03 122.19,39.47 C124.90,35.91 136.17,43.35 139.98,38.96 C143.79,34.57 158.69,2.48 156.47,0.00 C154.25,-2.48 125.59,12.79 120.03,16.68 C114.47,20.57 107.95,28.81 106.42,34.99 C104.89,41.17 108.61,65.37 106.28,72.34 C103.95,79.31 87.79,91.27 85.46,97.76 C83.13,104.25 87.27,124.96 85.27,130.73 C83.27,136.50 70.96,147.89 67.42,149.67 C63.88,151.45 57.59,145.14 53.45,146.71 C49.31,148.28 32.02,157.02 30.17,163.79 C28.32,170.56 39.53,199.62 36.81,207.65 C34.09,215.68 9.82,230.31 5.73,236.05 C1.64,241.79 -1.79,260.29 0.00,259.31 Z"
            ></path>
          </svg>
        </a>
        <ul class="toplinks">
          <li><a href="/">Home</a></li>
          <li><a href="/posts/">Posts</a></li>
          <li><a href="/books/">Books</a></li>
          <li><a href="/contact/">Contact</a></li>
          <li><a href="/index.xml">RSS</a></li>
          <li>
            <button class="search-trigger" id="search-trigger" type="button" aria-haspopup="dialog" aria-controls="search-modal">
              Search <kbd>⌘K</kbd>
            </button>
          </li>
        </ul>
      </div>
    </header>

    <main class:list={['main', { 'main--wide': wide }]}>
      <slot />
    </main>

    <footer class="footer">
      <div class="footer-inner">
        <span>© {new Date().getFullYear()} Davide Muttoni</span>
        <ul class="footer-links">
          <li><a href="https://github.com/mutt0-ds">GitHub</a></li>
          <li><a href="https://www.linkedin.com/in/davide-muttoni-77b134194/">LinkedIn</a></li>
          <li><a href="/index.xml">RSS</a></li>
        </ul>
      </div>
    </footer>

    <SearchModal />
  </body>
</html>

<style>
  .topbar-inner,
  .footer-inner,
  .main {
    max-width: 740px;
    margin: 0 auto;
    padding: 0 clamp(20px, 5vw, 32px);
  }

  .main {
    position: relative;
  }

  .main--wide {
    max-width: 1100px;
  }

  .topbar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 26px;
    padding-bottom: 26px;
    font-size: 0.9rem;
  }

  .mark {
    display: flex;
    align-items: center;
    text-decoration: none;
  }

  .mark-icon {
    width: 17px;
    height: 27px;
    display: block;
  }

  .mark-icon path {
    fill: var(--accent);
    transition: fill 0.15s ease;
  }

  .mark:hover .mark-icon path,
  .mark:focus-visible .mark-icon path {
    fill: var(--lake-deep);
  }

  .toplinks {
    display: flex;
    align-items: center;
    gap: clamp(14px, 3vw, 26px);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .toplinks a {
    text-decoration: none;
    color: var(--ink-70);
    padding-bottom: 3px;
    border-bottom: 1px solid transparent;
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .toplinks a:hover,
  .toplinks a:focus-visible {
    color: var(--accent);
    border-color: var(--accent);
  }

  .search-trigger {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--ink-70);
    background: none;
    border: none;
    padding: 0 0 3px;
    cursor: pointer;
    border-bottom: 1px solid transparent;
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .search-trigger:hover,
  .search-trigger:focus-visible {
    color: var(--accent);
    border-color: var(--accent);
  }

  .search-trigger kbd {
    font-family: var(--font-body);
    font-size: 0.72rem;
    color: var(--ink-45);
    background: var(--paper-shade);
    border: 1px solid var(--hairline);
    border-radius: 4px;
    padding: 1px 5px;
  }

  .footer {
    margin-top: clamp(40px, 7vw, 60px);
    border-top: 1px solid var(--hairline);
  }

  .footer-inner {
    padding-top: 22px;
    padding-bottom: clamp(40px, 6vw, 56px);
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    justify-content: space-between;
    font-size: 0.85rem;
    color: var(--ink-45);
  }

  .footer-links {
    display: flex;
    gap: 18px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer-links a {
    text-decoration: none;
    color: var(--ink-70);
    border-bottom: 1px solid transparent;
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .footer-links a:hover,
  .footer-links a:focus-visible {
    color: var(--accent);
    border-color: var(--accent);
  }

  @media (max-width: 640px) {
    .search-trigger kbd {
      display: none;
    }
  }
</style>
