---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <article class="prose">
    <slot />
  </article>
</BaseLayout>

<style>
  .prose {
    padding: clamp(16px, 3vw, 24px) 0 clamp(40px, 6vw, 60px);
  }

  .prose :global(.post-hero-wrap) {
    position: relative;
    margin: 0 0 clamp(20px, 4vw, 30px);
  }

  .prose :global(.post-hero) {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: 8px;
  }

  .prose :global(.post-hero-wrap)::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -3px;
    height: 3px;
    border-radius: 0 0 8px 8px;
    background: linear-gradient(90deg, var(--lake-deep), var(--accent), var(--lake-light));
    opacity: 0.85;
  }

  .prose :global(h2),
  .prose :global(h3) {
    font-family: var(--font-display);
    font-weight: 400;
    line-height: 1.25;
    margin: 1.6em 0 0.6em;
  }

  .prose :global(h2) {
    font-size: clamp(1.3rem, 2.6vw, 1.6rem);
  }

  .prose :global(h3) {
    font-size: clamp(1.1rem, 2.2vw, 1.3rem);
  }

  .prose :global(p) {
    margin: 0 0 1.1em;
    max-width: 68ch;
    font-size: 1.03rem;
    line-height: 1.7;
    color: var(--ink-70);
  }

  .prose :global(a) {
    color: var(--accent);
  }

  .prose :global(strong) {
    color: var(--ink);
  }

  .prose :global(ul),
  .prose :global(ol) {
    max-width: 68ch;
    padding-left: 1.3em;
    color: var(--ink-70);
    line-height: 1.7;
  }

  .prose :global(img),
  .prose :global(video) {
    max-width: 100%;
    height: auto;
    border-radius: 4px;
    margin: 0.4em 0;
  }

  .prose :global(pre) {
    background: var(--paper-shade);
    padding: 1em;
    overflow-x: auto;
    border-radius: 6px;
    font-size: 0.9rem;
  }

  .prose :global(code) {
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.92em;
  }

  .prose :global(p code) {
    background: var(--accent-soft);
    padding: 0.1em 0.35em;
    border-radius: 3px;
  }

  .prose :global(blockquote) {
    margin: 1.2em 0;
    padding-left: 1em;
    border-left: 3px solid var(--accent);
    color: var(--ink-70);
    font-style: italic;
  }
</style>
