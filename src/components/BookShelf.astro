---
import type { CollectionEntry } from 'astro:content';

interface Props {
  books: CollectionEntry<'books'>[];
}

const { books } = Astro.props;

// A repeating cycle of hand-tuned height/tilt profiles — gives the shelf an
// organic, varied silhouette (like a real shelf) without true randomness,
// so the layout stays stable across rebuilds.
const PROFILES = [
  { h: 150, tilt: -1.2 },
  { h: 232, tilt: 0.8 },
  { h: 182, tilt: -0.6 },
  { h: 162, tilt: 1.3 },
  { h: 152, tilt: -1.6 },
  { h: 140, tilt: 0.5 },
  { h: 212, tilt: -0.9 },
  { h: 192, tilt: 1.1 },
];

// Real book titles vary far more than the height profiles above were tuned
// for, and CSS text-overflow:ellipsis doesn't reliably render in this
// vertical-writing-mode + flex setup — so truncate for real, with an actual
// "…" character, sized to what each spine's own height can hold.
// Measured directly in-browser (Iowan Old Style/Palatino/Georgia @ 0.82rem,
// vertical-rl): ~5.6-6.5px per character across 10 real titles, average 6.06.
// Budget at 6.6px/char — just above the observed max — for a small safety
// margin without truncating harder than necessary.
const PX_PER_CHAR = 6.6;
function truncateForHeight(title: string, height: number): string {
  const maxChars = Math.floor((height - 28) / PX_PER_CHAR);
  if (title.length <= maxChars) return title;
  return `${title.slice(0, Math.max(maxChars - 1, 1)).trimEnd()}…`;
}
---

<ul class="shelf">
  {
    books.map((book, i) => {
      const profile = PROFILES[i % PROFILES.length];
      return (
        <li class="spine">
          <a href={`/books/${book.id}/`} style={`--h:${profile.h}px;--tilt:${profile.tilt}deg`} title={book.data.title}>
            {truncateForHeight(book.data.title, profile.h)}
          </a>
        </li>
      );
    })
  }
</ul>
<div class="shelf-ledge" aria-hidden="true"></div>

<style>
  .shelf {
    list-style: none;
    margin: 0;
    padding: 6px 4px 0;
    display: flex;
    align-items: flex-end;
    gap: 8px;
    overflow-x: auto;
    overflow-y: hidden;
    scrollbar-width: thin;
  }

  .shelf-ledge {
    height: 2px;
    margin: 0 4px 20px;
    background: linear-gradient(90deg, transparent, var(--hairline) 10%, var(--accent) 45%, var(--hairline) 90%, transparent);
    opacity: 0.55;
  }

  .spine {
    flex: none;
  }

  .spine a {
    display: flex;
    align-items: flex-end;
    justify-content: flex-end;
    padding: 14px 6px;
    width: 40px;
    height: var(--h, 160px);
    overflow: hidden;
    border-radius: 3px 3px 1px 1px;
    text-decoration: none;
    color: var(--ink);
    writing-mode: vertical-rl;
    white-space: nowrap;
    text-overflow: ellipsis;
    font-family: var(--font-display);
    font-size: 0.82rem;
    line-height: 1.15;
    background-image: linear-gradient(180deg, var(--spine-sheen) 0%, transparent 48%);
    box-shadow: inset -3px 0 0 rgba(0, 0, 0, 0.06);
    transform: rotate(var(--tilt, 0deg));
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .spine a:hover,
  .spine a:focus-visible {
    transform: translateY(-10px) rotate(calc(var(--tilt, 0deg) - 1deg));
    box-shadow: 0 10px 16px -8px rgba(0, 0, 0, 0.28), inset -3px 0 0 rgba(0, 0, 0, 0.06);
  }

  .spine:nth-child(4n+1) a {
    background-color: var(--spine-1);
  }
  .spine:nth-child(4n+2) a {
    background-color: var(--spine-2);
  }
  .spine:nth-child(4n+3) a {
    background-color: var(--spine-3);
  }
  .spine:nth-child(4n+4) a {
    background-color: var(--spine-4);
  }
</style>
