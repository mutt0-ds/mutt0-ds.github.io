---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { formatDate } from '../../lib/text';

const books = (await getCollection('books')).sort(
  (a, b) => b.data.finished.valueOf() - a.data.finished.valueOf()
);
---

<BaseLayout title="Books — Davide Muttoni" description="Everything I've read, with a one-line take on each." wide>
  <h1 class="page-title">The whole shelf</h1>
  <p class="page-lead">{books.length} books, most recently finished first.</p>
  <ul class="book-grid">
    {
      books.map((book) => (
        <li>
          <a class="book-card" href={`/books/${book.id}/`}>
            <img
              class="book-cover"
              src={book.data.image}
              alt={book.data.title}
              loading="lazy"
              decoding="async"
              onerror="this.style.visibility='hidden'"
            />
            <span class="book-card-title">{book.data.title}</span>
            <span class="book-card-author">{book.data.author}</span>
            <span class="book-card-meta">
              <span>{book.data.score}</span>
              <span>{formatDate(book.data.finished)}</span>
            </span>
          </a>
        </li>
      ))
    }
  </ul>
</BaseLayout>

<style>
  .book-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 24px 16px;
  }

  .book-card {
    display: flex;
    flex-direction: column;
    gap: 6px;
    text-decoration: none;
    color: var(--ink);
  }

  .book-cover {
    aspect-ratio: 2 / 3;
    width: 100%;
    object-fit: cover;
    border-radius: 4px;
    background: var(--paper-shade);
  }

  .book-card-title {
    font-family: var(--font-display);
    font-size: 0.95rem;
    line-height: 1.3;
  }

  .book-card-author {
    font-size: 0.8rem;
    color: var(--ink-45);
  }

  .book-card-meta {
    font-size: 0.78rem;
    color: var(--ink-70);
    display: flex;
    justify-content: space-between;
    gap: 8px;
  }

  .book-card:hover .book-card-title,
  .book-card:focus-visible .book-card-title {
    color: var(--accent);
  }
</style>
