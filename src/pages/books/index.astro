---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BookFan from '../../components/BookFan.astro';
import { getCollection } from 'astro:content';
import { formatDate, stripLeadingEmoji, countStars } from '../../lib/text';

const books = (await getCollection('books')).sort((a, b) => {
  const byRating = countStars(b.data.score) - countStars(a.data.score);
  if (byRating !== 0) return byRating;
  return b.data.finished.valueOf() - a.data.finished.valueOf();
});
const slugs = books.map((book) => book.id);
---

<BaseLayout title="Books" description={`Every book on my shelf`} wide>
  <BookFan books={books} />
  <div class="book-hero">
    <h1 class="page-title">The whole shelf</h1>
    <p class="page-lead">
      Here's a list of books I've read, with some scattered notes. They're sorted by how much I liked them, totally subjective and partial, as usual.
    Feel free to browse the notes, but don't expect anything comprehensive.
    You'll find technical, psychology, lifestyle, history, and science books, basically anything I managed to take notes on.
    I usually don't review fiction, but a few are included too.
    </p>
    <div class="book-actions">
      <button class="random-book-btn" id="random-book" type="button">🎲 Surprise me</button>
      <span class="book-actions-cap">{books.length} books - <a href="/contact/">got a recommendation?</a></span>
    </div>
  </div>

  <ul class="book-grid">
    {
      books.map((book) => (
        <li>
          <a class="book-card" href={`/books/${book.id}/`}>
            <div class="book-cover-wrap">
              <img
                class="book-cover"
                src={book.data.image}
                alt={book.data.title}
                loading="lazy"
                decoding="async"
                onerror="this.style.visibility='hidden'"
              />
            </div>
            {book.data.badges.length > 0 && (
              <span class="book-card-badges">
                {book.data.badges.slice(0, 2).map((badge) => (
                  <span class="book-card-badge">{stripLeadingEmoji(badge)}</span>
                ))}
              </span>
            )}
            <span class="book-card-title">{book.data.title}</span>
            <span class="book-card-author">{book.data.author}</span>
            <span class="book-card-meta">
              <span>{book.data.score}</span>
              <span>{formatDate(book.data.finished)}</span>
            </span>
          </a>
        </li>
      ))
    }
  </ul>
</BaseLayout>

<script define:vars={{ slugs }}>
  document.getElementById('random-book')?.addEventListener('click', () => {
    const slug = slugs[Math.floor(Math.random() * slugs.length)];
    window.location.href = `/books/${slug}/`;
  });
</script>

<style>
  .book-hero {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .page-lead {
    max-width: 72ch;
  }

  .book-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 18px;
    margin: 0 0 clamp(28px, 5vw, 40px);
  }

  .random-book-btn {
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--ink-70);
    background: var(--paper-shade);
    border: 1px solid var(--hairline);
    border-radius: 999px;
    padding: 9px 18px;
    cursor: pointer;
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .random-book-btn:hover,
  .random-book-btn:focus-visible {
    color: var(--accent);
    border-color: var(--accent);
  }

  .book-actions-cap {
    font-size: 0.85rem;
    color: var(--ink-45);
    padding-left: 18px;
    border-left: 1px solid var(--hairline);
  }

  .book-actions-cap a {
    color: var(--accent);
  }

  @media (max-width: 480px) {
    .book-actions-cap {
      padding-left: 0;
      border-left: none;
    }
  }

  .book-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 24px 16px;
  }

  .book-card {
    display: flex;
    flex-direction: column;
    gap: 6px;
    text-decoration: none;
    color: var(--ink);
  }

  .book-cover-wrap {
    border-radius: 4px;
    overflow: hidden;
  }

  .book-cover {
    display: block;
    aspect-ratio: 2 / 3;
    width: 100%;
    object-fit: cover;
    background: var(--paper-shade);
  }

  .book-card-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    margin-top: 2px;
  }

  .book-card-badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 0.68rem;
    line-height: 1.4;
    color: var(--ink-70);
    background: var(--paper-shade);
    border: 1px solid var(--hairline);
    padding: 1px 8px 1px 6px;
    border-radius: 999px;
    white-space: nowrap;
  }

  .book-card-badge::before {
    content: '';
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--accent);
    flex: none;
  }

  .book-card-title {
    font-family: var(--font-display);
    font-size: 0.95rem;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    min-height: 2.6em;
  }

  .book-card-author {
    font-size: 0.8rem;
    color: var(--ink-45);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .book-card-meta {
    font-size: 0.78rem;
    color: var(--ink-70);
    display: flex;
    justify-content: space-between;
    gap: 8px;
  }

  .book-card:hover .book-card-title,
  .book-card:focus-visible .book-card-title {
    color: var(--accent);
  }
</style>
